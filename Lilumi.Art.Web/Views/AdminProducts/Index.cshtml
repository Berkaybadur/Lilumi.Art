@model IReadOnlyList<Lilumi.Art.Application.Contracts.Products.ProductDto>
@{
    ViewData["Title"] = "Admin Urunler";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Admin Urun Yonetimi</h2>
    <a asp-action="Create" class="btn btn-dark">Yeni Urun</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Urun</th>
            <th>Fiyat</th>
            <th>Kaynak</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Price TL</td>
                <td>@item.SourcePlatform</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Duzenle</a>
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                        <button class="btn btn-sm btn-outline-danger" type="submit">Pasiflestir</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
