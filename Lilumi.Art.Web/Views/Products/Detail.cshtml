@model Lilumi.Art.Web.Models.Products.ProductDetailViewModel
@{
    ViewData["Title"] = "Urun Detay";
}

@if (Model.Product is null)
{
    <div class="alert alert-danger">Urun bulunamadi.</div>
    return;
}

<div class="row g-4">
    <div class="col-md-6">
        <img src="@Model.Product.ImageUrl" alt="@Model.Product.Name" class="img-fluid rounded shadow-sm" />
    </div>
    <div class="col-md-6">
        @if (!string.IsNullOrWhiteSpace(Model.Product.LogoUrl))
        {
            <img src="@Model.Product.LogoUrl" alt="Shop logo" style="max-height:42px;" class="mb-2" />
        }
        <h2>@Model.Product.Name</h2>
        <p class="text-muted">@Model.Product.Description</p>
        <p class="fs-4 fw-bold">@Model.Product.Price TL</p>
        <a href="@Model.Product.SourceProductUrl" target="_blank" class="btn btn-outline-secondary mb-3">Shopierde Ac</a>

        <hr />
        <h5>Talep Formu</h5>
        <form asp-action="Detail" method="post">
            <input type="hidden" asp-for="InquiryForm.ProductId" />
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="mb-2">
                <label asp-for="InquiryForm.FullName" class="form-label"></label>
                <input asp-for="InquiryForm.FullName" class="form-control" />
            </div>
            <div class="mb-2">
                <label asp-for="InquiryForm.Email" class="form-label"></label>
                <input asp-for="InquiryForm.Email" class="form-control" />
            </div>
            <div class="mb-2">
                <label asp-for="InquiryForm.Phone" class="form-label"></label>
                <input asp-for="InquiryForm.Phone" class="form-control" />
            </div>
            <div class="mb-2">
                <label asp-for="InquiryForm.Message" class="form-label"></label>
                <textarea asp-for="InquiryForm.Message" class="form-control" rows="4"></textarea>
            </div>
            <button type="submit" class="btn btn-dark">Formu Gonder</button>
        </form>
    </div>
</div>
